{
  "name": "fabric-mcp",
  "version": "1.0.0",
  "description": "MCP server for Fabric.js documentation — scrapes, caches, and serves fabricjs.com via MCP tools",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastmcp": "^3.4.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.51.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
